{
  "name": "slack-github-action",
  "version": "1.0.6",
  "description": "Sends Slack notifications about the results of GitHub Actions workflows",
  "main": "dist/index.js",
  "scripts": {
    "start": "npm run build && node .",
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.js",
    "lint": "eslint src",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "local": "esbuild src/local-index.ts --bundle --platform=node --format=cjs --outfile=build/local-index.js && node build/local-index.js"
  },
  "author": "Ruchira (Richie) Jayasekara <me@ruchij.com>",
  "license": "ISC",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@aws-sdk/client-ssm": "^3.1071.0",
    "@aws-sdk/client-sts": "^3.1071.0",
    "axios": "^1.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@swc/core": "^1.15.41",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "jest": "^30.4.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
